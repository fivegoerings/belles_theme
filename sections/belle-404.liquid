{% comment %}
  Belle's Performance Tennis - Custom 404 Page
  Matches Belle's brand: green/gold palette, Bebas Neue headings, 
  Source Sans Pro body, same CTA pattern as the rest of the site.
{% endcomment %}

<style>
.belle-404 {
  --belle-green: #1a3c2a;
  --belle-green-light: #2a5a3a;
  --belle-gold: #c8a951;
  --belle-cream: #faf9f6;
  --belle-charcoal: #2d2d2d;

  background: var(--belle-cream);
  padding: 80px 24px;
  text-align: center;
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

/* Subtle court-line background */
.belle-404::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background:
    radial-gradient(ellipse at 30% 70%, rgba(26, 71, 42, 0.03) 0%, transparent 50%),
    radial-gradient(ellipse at 70% 30%, rgba(201, 162, 39, 0.03) 0%, transparent 50%);
  pointer-events: none;
}

.belle-404-container {
  max-width: 600px;
  position: relative;
  z-index: 1;
}

/* Tennis ball icon */
.belle-404-icon {
  width: 80px;
  height: 80px;
  margin: 0 auto 24px;
  background: linear-gradient(135deg, var(--belle-green) 0%, var(--belle-green-light) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 4px 16px rgba(26, 71, 42, 0.25),
    0 0 0 4px var(--belle-cream),
    0 0 0 6px rgba(201, 162, 39, 0.3);
}

.belle-404-icon svg {
  width: 36px;
  height: 36px;
  fill: var(--belle-gold);
}

/* 404 number */
.belle-404-code {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 72px;
  color: var(--belle-green);
  margin: 0;
  line-height: 1;
  letter-spacing: 4px;
  opacity: 0.15;
}

/* Heading */
.belle-404 h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 36px;
  color: var(--belle-green);
  margin: 8px 0 16px;
  letter-spacing: 1.5px;
  line-height: 1.2;
}

/* Message */
.belle-404-message {
  font-family: 'Source Sans Pro', sans-serif;
  font-size: 17px;
  color: #666;
  line-height: 1.6;
  margin: 0 0 32px;
}

/* Links grid */
.belle-404-links {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 32px;
}

.belle-404-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 12px 24px;
  font-family: 'Source Sans Pro', sans-serif;
  font-size: 15px;
  font-weight: 600;
  text-decoration: none;
  border-radius: 8px;
  transition: all 0.3s ease;
  cursor: pointer;
}

.belle-404-link-primary {
  background: #f4b942;
  color: var(--belle-green);
  border: 2px solid #f4b942;
}

.belle-404-link-primary:hover {
  background: #f7c755;
  transform: translateY(-2px);
}

.belle-404-link-secondary {
  background: transparent;
  color: var(--belle-green);
  border: 2px solid var(--belle-green);
}

.belle-404-link-secondary:hover {
  background: var(--belle-green);
  color: #fff;
  transform: translateY(-2px);
}

/* Divider */
.belle-404-divider {
  width: 60px;
  height: 3px;
  background: var(--belle-gold);
  margin: 0 auto 24px;
  border-radius: 2px;
}

/* Help text */
.belle-404-help {
  font-family: 'Source Sans Pro', sans-serif;
  font-size: 14px;
  color: #999;
  margin: 0;
}

.belle-404-help a {
  color: var(--belle-green);
  text-decoration: none;
  font-weight: 600;
}

.belle-404-help a:hover {
  color: var(--belle-gold);
}

/* Responsive */
@media (max-width: 768px) {
  .belle-404 {
    padding: 60px 20px;
    min-height: 50vh;
  }

  .belle-404-code {
    font-size: 56px;
  }

  .belle-404 h1 {
    font-size: 28px;
  }

  .belle-404-message {
    font-size: 15px;
  }

  .belle-404-links {
    flex-direction: column;
    gap: 10px;
  }

  .belle-404-link {
    width: 100%;
    justify-content: center;
  }

  .belle-404-icon {
    width: 64px;
    height: 64px;
  }

  .belle-404-icon svg {
    width: 28px;
    height: 28px;
  }
}
</style>

<section class="belle-404">
  <div class="belle-404-container">
    
    <div class="belle-404-icon">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
        <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
      </svg>
    </div>

    <p class="belle-404-code">404</p>

    <h1>{{ section.settings.heading }}</h1>

    <p class="belle-404-message">{{ section.settings.message }}</p>

    <div class="belle-404-links">
      <a href="{{ routes.root_url }}" class="belle-404-link belle-404-link-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
        Back to Home
      </a>
      <a href="#" data-calendly-modal="true" class="belle-404-link belle-404-link-secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11zM9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z"/></svg>
        Book Your Appointment
      </a>
    </div>

    <div class="belle-404-divider"></div>

    <p class="belle-404-help">
      Looking for something specific? Try 
      <a href="/pages/racquet-stringing-prices-kansas-city-northland">Pricing</a>, 
      <a href="/pages/faq">FAQ</a>, or 
      <a href="/blogs/news">Blog</a>.
    </p>

  </div>
</section>

{% schema %}
{
  "name": "Belle's 404",
  "tag": "section",
  "class": "section-belle-404",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "This One Sailed Out"
    },
    {
      "type": "textarea",
      "id": "message",
      "label": "Message",
      "default": "The page you're looking for isn't here — it may have moved or the link might be outdated. Let's get you back on court."
    }
  ]
}
{% endschema %}
