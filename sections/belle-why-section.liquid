{% comment %}
  Belle's Performance Tennis - Why Choose Us Section (Enhanced with Images)
  To be placed between hero and other content
  Version: 1.1.0 - 2026-04-13 - Added optional Link URL field to reason cards
{% endcomment %}

{{ 'belle-why-section.css' | asset_url | stylesheet_tag }}

<style>
  a.belle-why-card {
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    display: block;
  }
</style>

<section class="belle-why">
  <div class="belle-why-container">
    
    <div class="belle-why-header">
      <h2>{{ section.settings.section_title }}</h2>
      {% if section.settings.section_subtitle != blank %}
        <p class="belle-why-subtitle">{{ section.settings.section_subtitle }}</p>
      {% endif %}
    </div>

    <div class="belle-why-grid">
      {% for block in section.blocks %}
        {% if block.settings.url != blank %}<a href="{{ block.settings.url }}" class="belle-why-card" {{ block.shopify_attributes }}>{% else %}<div class="belle-why-card" {{ block.shopify_attributes }}>{% endif %}
          
          {%- comment -%} Image Support - Display if image is uploaded {%- endcomment -%}
          {% if block.settings.image != blank %}
            <div class="belle-why-image">
              <img 
                src="{{ block.settings.image | image_url: width: 600 }}"
                srcset="{{ block.settings.image | image_url: width: 300 }} 300w,
                        {{ block.settings.image | image_url: width: 600 }} 600w,
                        {{ block.settings.image | image_url: width: 900 }} 900w"
                sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
                alt="{{ block.settings.image.alt | default: block.settings.title }}"
                loading="lazy"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
              >
            </div>
          {% else %}
            {%- comment -%} Fallback to icon if no image {%- endcomment -%}
            <div class="belle-why-icon">
              {% case block.settings.icon %}
                {% when 'machine' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"/></svg>
                {% when 'badge' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M23 12l-2.44-2.79.34-3.69-3.61-.82-1.89-3.2L12 2.96 8.6 1.5 6.71 4.69 3.1 5.5l.34 3.7L1 12l2.44 2.79-.34 3.7 3.61.82L8.6 22.5l3.4-1.47 3.4 1.46 1.89-3.19 3.61-.82-.34-3.69L23 12zm-12.91 4.72l-3.8-3.81 1.48-1.48 2.32 2.33 5.85-5.87 1.48 1.48-7.33 7.35z"/></svg>
                {% when 'racquet' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M11 23.59v-3.6c5.01-.26 9-4.42 9-9.49C20 5.26 15.74 1 10.5 1S1 5.26 1 10.5c0 4.95 3.44 9.93 8.57 10.42.01-.02.01-.04.01-.06.09-.16.18-.33.26-.5.04-.08.08-.16.12-.24.07-.17.14-.34.2-.51.02-.06.05-.13.07-.19.06-.17.12-.35.18-.52.01-.05.03-.09.04-.14.09-.3.17-.6.24-.91l.06-.3c.05-.29.1-.58.13-.87.01-.09.02-.18.02-.27.04-.43.07-.87.07-1.33 0-3.74-2.83-6.82-6.47-7.21-.01.01-.02.03-.03.04-.18.21-.37.41-.57.59-.19.18-.38.35-.59.51-.21.17-.42.32-.64.47-.22.15-.45.29-.68.42-.23.13-.46.25-.7.36-.24.11-.48.22-.73.31-.25.1-.51.18-.77.26-.26.08-.52.15-.79.21-.27.06-.54.12-.81.16-.27.04-.55.07-.82.09-.28.02-.56.04-.84.04s-.56-.01-.84-.04c-.28-.02-.55-.05-.82-.09-.27-.04-.54-.1-.81-.16-.27-.06-.53-.13-.79-.21-.26-.08-.52-.17-.77-.26-.25-.09-.49-.2-.73-.31-.24-.11-.47-.23-.7-.36-.23-.13-.46-.27-.68-.42-.22-.15-.43-.3-.64-.47-.21-.16-.4-.33-.59-.51-.2-.18-.39-.38-.57-.59-.01-.01-.02-.02-.03-.04-3.64.39-6.47 3.47-6.47 7.21 0 .46.03.9.07 1.33.01.09.02.18.02.27.04.29.08.58.13.87l.06.3c.07.31.15.61.24.91.01.05.03.09.04.14.06.18.12.35.18.52.02.06.05.13.07.19.06.18.13.35.2.51.04.08.08.16.12.24.08.17.17.34.26.5 0 .02.01.04.01.06C7.56 20.93 11 23.33 16.43 23.59z"/></svg>
                {% when 'heart' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M16.5 3c-1.74 0-3.41.81-4.5 2.09C10.91 3.81 9.24 3 7.5 3 4.42 3 2 5.42 2 8.5c0 3.78 3.4 6.86 8.55 11.54L12 21.35l1.45-1.32C18.6 15.36 22 12.28 22 8.5 22 5.42 19.58 3 16.5 3zm-4.4 15.55l-.1.1-.1-.1C7.14 14.24 4 11.39 4 8.5 4 6.5 5.5 5 7.5 5c1.54 0 3.04.99 3.57 2.36h1.87C13.46 5.99 14.96 5 16.5 5c2 0 3.5 1.5 3.5 3.5 0 2.89-3.14 5.74-7.9 10.05z"/></svg>
                {% else %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
              {% endcase %}
            </div>
          {% endif %}

          <div class="belle-why-content">
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.description }}</p>
          </div>
        {% if block.settings.url != blank %}</a>{% else %}</div>{% endif %}
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Why Belle's (with Images)",
  "tag": "section",
  "class": "section-belle-why",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Why Belle's Performance Tennis?"
    },
    {
      "type": "textarea",
      "id": "section_subtitle",
      "label": "Section Subtitle (optional)",
      "info": "Brief description under the title"
    }
  ],
  "blocks": [
    {
      "type": "reason",
      "name": "Reason",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Upload an image to replace the icon. Recommended: 600x400px or similar aspect ratio. Leave blank to use icon instead."
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon (used if no image)",
          "options": [
            {
              "value": "machine",
              "label": "Tool/Machine"
            },
            {
              "value": "badge",
              "label": "Badge/Certification"
            },
            {
              "value": "racquet",
              "label": "Tennis Racquet"
            },
            {
              "value": "heart",
              "label": "Heart/Community"
            },
            {
              "value": "check",
              "label": "Checkmark"
            }
          ],
          "default": "machine"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Reason Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Description of this reason"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL",
          "info": "Optional. Makes the card clickable. Use /pages/demo-racquet-program for the demo card."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Belle's (with Images)",
      "blocks": [
        {
          "type": "reason",
          "settings": {
            "icon": "machine",
            "title": "Professional-Grade Equipment",
            "description": "Your racquet is strung on a Gamma Progression II ELS - the same equipment trusted by pro shops nationwide."
          }
        },
        {
          "type": "reason",
          "settings": {
            "icon": "badge",
            "title": "USRSA Member",
            "description": "Member of the U.S. Racquet Stringers Association, committed to quality and professional stringing standards."
          }
        },
        {
          "type": "reason",
          "settings": {
            "icon": "racquet",
            "title": "Free Solinco Demo Racquets",
            "description": "Never be without a racquet. Borrow a premium demo while we work on yours - completely free."
          }
        },
        {
          "type": "reason",
          "settings": {
            "icon": "heart",
            "title": "Founded by a Staley Tennis Parent",
            "description": "We understand tournament schedules, string preferences, and the importance of having your racquet ready when you need it."
          }
        }
      ]
    }
  ]
}
{% endschema %}
