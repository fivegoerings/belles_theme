{% comment %}
  belle-shop-strings.liquid
  Standalone section. Add to any page via the Shopify editor.
  Manage strings entirely in the section settings -- no code edits needed.
{% endcomment %}

<div class="bss-wrapper">
  <div class="bss-card">
    <button
      class="bss-header"
      aria-expanded="false"
      aria-controls="bss-list"
      onclick="bssToggle(this)"
    >
      <div class="bss-icon-box" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
          <ellipse cx="14" cy="13" rx="10" ry="11" stroke="#1a3c2a" stroke-width="2" fill="none"/>
          <line x1="10" y1="3.5" x2="10" y2="22.5" stroke="#1a3c2a" stroke-width="1.2" stroke-linecap="round"/>
          <line x1="14" y1="2.2" x2="14" y2="23.8" stroke="#1a3c2a" stroke-width="1.2" stroke-linecap="round"/>
          <line x1="18" y1="3.5" x2="18" y2="22.5" stroke="#1a3c2a" stroke-width="1.2" stroke-linecap="round"/>
          <line x1="4.5" y1="10" x2="23.5" y2="10" stroke="#1a3c2a" stroke-width="1.2" stroke-linecap="round"/>
          <line x1="4" y1="13" x2="24" y2="13" stroke="#1a3c2a" stroke-width="1.2" stroke-linecap="round"/>
          <line x1="4.5" y1="16" x2="23.5" y2="16" stroke="#1a3c2a" stroke-width="1.2" stroke-linecap="round"/>
          <rect x="12.5" y="23.5" width="3" height="4" rx="1" fill="#1a3c2a"/>
        </svg>
      </div>

      <div class="bss-header-text">
        <span class="bss-title">{{ section.settings.card_title }}</span>
        <span class="bss-subtitle bss-subtitle--closed">
          {%- assign string_count = section.blocks | size -%}
          {{ string_count }} string{% if string_count != 1 %}s{% endif %} in stock -- tap to browse
        </span>
        <span class="bss-subtitle bss-subtitle--open" hidden>Hide string lineup</span>
      </div>

      <svg class="bss-chevron" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M4.5 6.75L9 11.25L13.5 6.75" stroke="#1a3c2a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <div id="bss-list" class="bss-list" hidden>
      <div class="bss-divider"></div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'string_item' -%}
          <div class="bss-row{% unless forloop.last %} bss-row--bordered{% endunless %}" {{ block.shopify_attributes }}>
            <div class="bss-dot" aria-hidden="true"></div>
            <div>
              <div class="bss-string-name">{{ block.settings.string_name }}</div>
              {%- if block.settings.string_description != blank -%}
                <div class="bss-string-desc">{{ block.settings.string_description }}</div>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- if section.settings.cta_url != blank -%}
        <div class="bss-cta">
          <a href="{{ section.settings.cta_url }}" class="bss-cta-link">
            {{ section.settings.cta_label }} &rarr;
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  .bss-wrapper {
    padding: 0 16px;
    margin: 0 auto;
    max-width: 900px;
  }

  .bss-card {
    background: #ffffff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.07);
  }

  .bss-header {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 16px;
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
  }

  .bss-icon-box {
    width: 52px;
    height: 52px;
    border-radius: 12px;
    background: #e6ede9;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .bss-header-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .bss-title {
    font-size: 17px;
    font-weight: 700;
    color: #1a3c2a;
    line-height: 1.2;
  }

  .bss-subtitle {
    font-size: 14px;
    color: #666666;
    line-height: 1.4;
  }

  .bss-chevron {
    flex-shrink: 0;
    transition: transform 0.25s ease;
  }

  .bss-header[aria-expanded="true"] .bss-chevron {
    transform: rotate(180deg);
  }

  .bss-header[aria-expanded="true"] .bss-subtitle--closed {
    display: none;
  }

  .bss-header[aria-expanded="false"] .bss-subtitle--open {
    display: none;
  }

  .bss-header[aria-expanded="true"] .bss-subtitle--open {
    display: block !important;
  }

  .bss-divider {
    height: 1px;
    background: #ebebeb;
    margin: 0 16px;
  }

  .bss-row {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 12px 16px;
  }

  .bss-row--bordered {
    border-bottom: 1px solid #f0f0f0;
  }

  .bss-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #b5932a;
    margin-top: 6px;
    flex-shrink: 0;
  }

  .bss-string-name {
    font-size: 15px;
    font-weight: 700;
    color: #1a3c2a;
    margin-bottom: 2px;
  }

  .bss-string-desc {
    font-size: 15px;
    color: #555555;
    line-height: 1.45;
  }

  .bss-cta {
    padding: 10px 16px 14px;
    text-align: right;
  }

  .bss-cta-link {
    font-size: 13px;
    font-weight: 600;
    color: #1a3c2a;
    text-decoration: none;
    letter-spacing: 0.01em;
  }

  .bss-cta-link:hover {
    text-decoration: underline;
  }
</style>

<script>
  function bssToggle(btn) {
    var list = document.getElementById('bss-list');
    var expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    if (expanded) {
      list.hidden = true;
    } else {
      list.hidden = false;
    }
  }
</script>

{% schema %}
{
  "name": "Shop Strings",
  "tag": "section",
  "class": "belle-shop-strings",
  "settings": [
    {
      "type": "text",
      "id": "card_title",
      "label": "Card title",
      "default": "Shop Strings"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link (e.g. /collections/strings)"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA link text",
      "default": "View all strings"
    }
  ],
  "blocks": [
    {
      "type": "string_item",
      "name": "String",
      "settings": [
        {
          "type": "text",
          "id": "string_name",
          "label": "String name",
          "default": "Solinco Hyper-G"
        },
        {
          "type": "textarea",
          "id": "string_description",
          "label": "Description",
          "default": "Firm, snappy co-poly with heavy spin and excellent control."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop Strings",
      "blocks": [
        {
          "type": "string_item",
          "settings": {
            "string_name": "Solinco Hyper-G",
            "string_description": "Firm, snappy co-poly with heavy spin and excellent control."
          }
        },
        {
          "type": "string_item",
          "settings": {
            "string_name": "Solinco Tour Bite",
            "string_description": "Aggressive square profile that bites the ball for maximum spin."
          }
        },
        {
          "type": "string_item",
          "settings": {
            "string_name": "Solinco Confidential",
            "string_description": "Soft co-poly with a comfortable feel and good pop."
          }
        },
        {
          "type": "string_item",
          "settings": {
            "string_name": "Solinco Vanquish",
            "string_description": "Silky multifilament with arm-friendly flex and lively response."
          }
        },
        {
          "type": "string_item",
          "settings": {
            "string_name": "Solinco Revolution",
            "string_description": "Round co-poly balancing power and control with solid durability."
          }
        }
      ]
    }
  ]
}
{% endschema %}
