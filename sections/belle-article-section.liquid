{% comment %}
  Belle's Performance Tennis - Blog Article Section
  Custom styled single blog post matching Belle's brand
{% endcomment %}

{{ 'section-belle-article.css' | asset_url | stylesheet_tag }}

<article class="belle-article" itemscope itemtype="https://schema.org/BlogPosting">
  <div class="belle-article-container">
    
    <!-- Hero Image -->
    {% if article.image %}
    <div class="belle-article-hero">
      <img 
        src="{{ article.image | image_url: width: 1400 }}" 
        alt="{{ article.image.alt | escape | default: article.title }}"
        itemprop="image"
        loading="eager"
        width="1400"
        height="{{ 1400 | divided_by: article.image.aspect_ratio | round }}"
      >
    </div>
    {% endif %}
    
    <!-- Article Header -->
    <header class="belle-article-header">
      <div class="belle-article-meta">
        <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}" itemprop="datePublished">
          {{ article.published_at | date: '%B %d, %Y' }}
        </time>
        {% if article.author != blank %}
        <span class="belle-article-author" itemprop="author">by {{ article.author }}</span>
        {% endif %}
      </div>
      
      <h1 class="belle-article-title" itemprop="headline">{{ article.title }}</h1>
      
      {% if article.tags.size > 0 %}
      <div class="belle-article-tags">
        {% for tag in article.tags %}
        <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="belle-article-tag">{{ tag }}</a>
        {% endfor %}
      </div>
      {% endif %}
    </header>
    
    <!-- Article Content -->
    {%- comment -%}
      The belle-article-title above is the page's h1. Authors sometimes add an
      H1 inside the article body in the blog editor, producing duplicate h1s on
      the page — demote any body h1s to h2 at render time.
    {%- endcomment -%}
    <div class="belle-article-content rte" itemprop="articleBody">
      {{ article.content | replace: '<h1>', '<h2>' | replace: '<h1 ', '<h2 ' | replace: '</h1>', '</h2>' }}
    </div>
    
    <!-- Share Section -->
    <div class="belle-article-share">
      <span class="belle-article-share-label">Share this article:</span>
      <div class="belle-article-share-buttons">
        <a 
          href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ article.url }}" 
          target="_blank" 
          rel="noopener noreferrer"
          class="belle-article-share-btn belle-article-share-facebook"
          aria-label="Share on Facebook"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/></svg>
        </a>
        <a 
          href="https://twitter.com/intent/tweet?text={{ article.title | url_encode }}&url={{ shop.url }}{{ article.url }}" 
          target="_blank" 
          rel="noopener noreferrer"
          class="belle-article-share-btn belle-article-share-twitter"
          aria-label="Share on Twitter"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a 
          href="mailto:?subject={{ article.title | url_encode }}&body=Check out this article: {{ shop.url }}{{ article.url }}" 
          class="belle-article-share-btn belle-article-share-email"
          aria-label="Share via Email"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
        </a>
      </div>
    </div>
    
    <!-- Back to Blog -->
    <div class="belle-article-back">
      <a href="{{ blog.url }}" class="belle-article-back-link">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
        Back to {{ blog.title }}
      </a>
    </div>
    
    <!-- Comments Section (if enabled) -->
    {% if blog.comments_enabled? %}
    <div class="belle-article-comments">
      {% if article.comments_count > 0 %}
      <h2 class="belle-article-comments-title">
        {{ article.comments_count }} {{ article.comments_count | pluralize: 'Comment', 'Comments' }}
      </h2>
      
      <div class="belle-article-comments-list">
        {% paginate article.comments by 10 %}
          {% for comment in article.comments %}
          <div class="belle-article-comment">
            <div class="belle-article-comment-header">
              <span class="belle-article-comment-author">{{ comment.author }}</span>
              <time datetime="{{ comment.created_at | date: '%Y-%m-%d' }}">
                {{ comment.created_at | date: '%B %d, %Y' }}
              </time>
            </div>
            <div class="belle-article-comment-content">
              {{ comment.content }}
            </div>
          </div>
          {% endfor %}
          
          {% if paginate.pages > 1 %}
          <nav class="belle-article-comments-pagination">
            {{ paginate | default_pagination }}
          </nav>
          {% endif %}
        {% endpaginate %}
      </div>
      {% endif %}
      
      <!-- Comment Form -->
      <div class="belle-article-comment-form">
        <h3 class="belle-article-comment-form-title">Leave a Comment</h3>
        
        {% form 'new_comment', article %}
          {% if form.errors %}
          <div class="belle-article-form-error">
            {{ form.errors | default_errors }}
          </div>
          {% endif %}
          
          {% if form.posted_successfully? %}
          <div class="belle-article-form-success">
            {% if blog.moderated? %}
              Your comment has been submitted and is awaiting moderation.
            {% else %}
              Thank you for your comment!
            {% endif %}
          </div>
          {% endif %}
          
          <div class="belle-article-form-row">
            <div class="belle-article-form-field">
              <label for="comment-author">Name</label>
              <input type="text" name="comment[author]" id="comment-author" value="{{ form.author }}" required>
            </div>
            <div class="belle-article-form-field">
              <label for="comment-email">Email</label>
              <input type="email" name="comment[email]" id="comment-email" value="{{ form.email }}" required>
            </div>
          </div>
          
          <div class="belle-article-form-field">
            <label for="comment-body">Comment</label>
            <textarea name="comment[body]" id="comment-body" rows="5" required>{{ form.body }}</textarea>
          </div>
          
          {% if blog.moderated? %}
          <p class="belle-article-form-note">All comments are moderated before being published.</p>
          {% endif %}
          
          <button type="submit" class="belle-article-form-submit">Post Comment</button>
        {% endform %}
      </div>
    </div>
    {% endif %}
    
  </div>
</article>

<script type="application/ld+json">
  {{ article | structured_data }}
</script>

{% schema %}
{
  "name": "Belle's Article",
  "tag": "section",
  "class": "belle-article-section",
  "settings": []
}
{% endschema %}
