{% comment %}
  Belle's Performance Tennis Shop - Hero Section (CONVERSION-OPTIMIZED)
  Version: 1.1.0 - 2026-04-13 - Added optional Link URL field to feature cards

  Changes from previous version:
  - Full-width background image with dark green overlay (CTA visible without scrolling on mobile)
  - Customer-benefit H1 instead of business name as H1
  - Business name as small byline above headline
  - Single-line trust bar replaces 3-paragraph description
  - Secondary CTA changed to "See Pricing" (captures comparison shoppers)
  - Badge reframed from "APPOINTMENT ONLY" to benefit-first text
  - Feature cards preserved below hero
  - v1.1.0: Feature cards now support optional Link URL (set in customizer per block)

  Strategy doc reference: Section 3 - Homepage Architecture
  LOCKED: Do not modify without data from GA4/Calendly showing conversion issue.
{% endcomment %}

<style>
      /* ============================================
         BELLE'S HERO - CONVERSION LAYOUT
         Background image + overlay + centered content
         ============================================ */


      .belle-hero-v2 {
        --belle-green: #1a3c2a;
        --belle-green-dark: #0f2e1a;
        --belle-gold: #c8a951;
        --belle-gold-light: #c8a951;
        --belle-cream: #faf9f6;
        --belle-charcoal: #2d2d2d;

       /* Contain z-index stacking so hero content doesn't bleed through the mobile menu drawer */
        isolation: isolate;
        position: relative;
        z-index: 0;


      }

      /* ---- Top Contact Bar ---- */
      .belle-topbar {
        background: var(--belle-green-dark);
        color: white;
        padding: 10px 20px;
        text-align: center;
        font-family: 'Source Sans Pro', -apple-system, BlinkMacSystemFont, sans-serif;
        font-size: 14px;
        letter-spacing: 0.5px;
        position: relative;
        z-index: 2;
      }

      .belle-topbar a {
        color: var(--belle-gold);
        text-decoration: none;
        font-weight: 600;
        transition: color 0.2s ease;
      }

      .belle-topbar a:hover {
        color: var(--belle-gold-light);
      }

      .belle-topbar-content {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 30px;
        flex-wrap: wrap;
      }

      .belle-topbar-item {
        display: flex;
        align-items: center;
        gap: 8px;
      }

  /* ---- Topbar height lock (prevents CLS from reflow) ---- */
  .belle-topbar {
    min-height: 76px;
  }

  @media (min-width: 651px) {
    .belle-topbar {
      min-height: 38px;
    }
  }



      .belle-topbar svg {
        width: 16px;
        height: 16px;
        fill: var(--belle-gold);
      }

      /* ---- Hero Background Image ---- */
      .belle-hero-bg {
        position: relative;
        min-height: 520px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
      }

      .belle-hero-bg-image {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
      }

      .belle-hero-bg-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 40%;
      }

      /* Dark green gradient overlay for text legibility */
      .belle-hero-bg::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(
          180deg,
          rgba(15, 46, 26, 0.92) 0%,
          rgba(26, 71, 42, 0.85) 40%,
          rgba(26, 71, 42, 0.80) 70%,
          rgba(15, 46, 26, 0.92) 100%
        );
        z-index: 1;
      }

      /* Subtle texture over the overlay */
      .belle-hero-bg::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-image:
          radial-gradient(ellipse at 20% 50%, rgba(201, 162, 39, 0.06) 0%, transparent 50%),
          radial-gradient(ellipse at 80% 30%, rgba(201, 162, 39, 0.04) 0%, transparent 50%);
        z-index: 2;
        pointer-events: none;
      }

      /* ---- Hero Content (centered over background) ---- */
      .belle-hero-content-v2 {
        position: relative;
        z-index: 3;
        text-align: center;
        max-width: 800px;
        padding: 50px 24px 60px;
      }

      /* Benefit badge */
      .belle-hero-badge-v2 {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(201, 162, 39, 0.15);
        border: 1px solid rgba(201, 162, 39, 0.4);
        color: var(--belle-gold);
        padding: 8px 20px;
        border-radius: 50px;
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin-bottom: 24px;
      }

      .belle-hero-badge-v2 svg {
        width: 16px;
        height: 16px;
        fill: var(--belle-gold);
      }

      /* Business name byline */
      .belle-hero-byline {
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--belle-gold);
        margin: 0 0 12px 0;
      }

      /* Customer-benefit H1 */
      .belle-hero-v2 h1 {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 44px;
        line-height: 1.1;
        color: #ffffff;
        margin: 0 0 8px 0;
        letter-spacing: 1px;
      }

      .belle-hero-v2 h1 span {
        color: var(--belle-gold);
      }

      /* Tagline / subhead */
      .belle-hero-tagline-v2 {
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 20px;
        line-height: 1.5;
        color: rgba(255, 255, 255, 0.85);
        margin: 0 0 28px 0;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
      }

      /* CTA buttons */
      .belle-cta-group-v2 {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 28px;
      }

      .belle-btn-v2 {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 16px 32px;
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 16px;
        font-weight: 700;
        text-decoration: none;
        border-radius: 8px;
        letter-spacing: 0.5px;
        transition: all 0.25s ease;
        cursor: pointer;
        border: 2px solid transparent;
      }

      .belle-btn-v2 svg {
        width: 20px;
        height: 20px;
        flex-shrink: 0;
      }

      .belle-btn-primary-v2 {
        background: var(--belle-gold);
        color: var(--belle-green-dark);
        border-color: var(--belle-gold);
      }

      .belle-btn-primary-v2 svg {
        fill: var(--belle-green-dark);
      }

      .belle-btn-primary-v2:hover {
        background: var(--belle-gold-light);
        border-color: var(--belle-gold-light);
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(201, 162, 39, 0.3);
      }

      /* Secondary CTA as plain text link */
      .belle-hero-text-link {
        color: rgba(255, 255, 255, 0.75);
        text-decoration: underline;
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 15px;
        font-weight: 600;
        display: inline-block;
        padding: 8px 4px;
        transition: color 0.2s ease;
      }

      .belle-hero-text-link:hover {
        color: #c8a951;
        text-decoration: none;
      }

      /* Trust bar */
      .belle-trust-bar {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 14px;
        color: rgba(255, 255, 255, 0.7);
      }

      .belle-trust-item {
        display: flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
      }

      .belle-trust-item svg {
        width: 14px;
        height: 14px;
        fill: var(--belle-gold);
        flex-shrink: 0;
      }

      .belle-trust-divider {
        width: 4px;
        height: 4px;
        background: rgba(255, 255, 255, 0.3);
        border-radius: 50%;
        flex-shrink: 0;
      }

      /* ---- Feature Cards ---- */
      .belle-features-wrapper-v2 {
        background: var(--belle-cream);
        padding: 0 24px 50px;
      }

      .belle-features-v2 {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        max-width: 1100px;
        margin: -40px auto 0;
        position: relative;
        z-index: 4;
      }

      .belle-feature-v2 {
        background: #ffffff;
        border-radius: 12px;
        padding: 28px 20px;
        text-align: center;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
        border: 1px solid rgba(26, 71, 42, 0.08);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }

      .belle-feature-v2:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
      }

      a.belle-feature-v2 {
        cursor: pointer;
        text-decoration: none;
        color: inherit;
        display: block;
      }

      .belle-feature-icon-v2 {
        width: 48px;
        height: 48px;
        margin: 0 auto 16px;
        background: rgba(26, 71, 42, 0.08);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .belle-feature-icon-v2 svg {
        width: 24px;
        height: 24px;
        fill: var(--belle-green);
      }

      .belle-feature-v2 h2 {
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 15px;
        font-weight: 700;
        color: var(--belle-green);
        margin: 0 0 8px 0;
        line-height: 1.3;
      }

      .belle-feature-v2 p {
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 14px;
        color: #666;
        margin: 0;
        line-height: 1.5;
      }

      /* ---- Responsive ---- */

      @media (max-width: 900px) {
        .belle-hero-bg {
          min-height: 480px;
        }

        .belle-hero-v2 h1 {
          font-size: 40px;
        }

        .belle-hero-tagline-v2 {
          font-size: 18px;
        }

        .belle-features-v2 {
          grid-template-columns: repeat(2, 1fr);
          gap: 16px;
          margin-top: -30px;
        }
      }

      @media (max-width: 650px) {
        .belle-topbar-content {
          flex-direction: column;
          gap: 6px;
        }

        .belle-hero-bg {
          min-height: 420px;
        }

        .belle-hero-content-v2 {
          padding: 36px 20px 44px;
        }

        .belle-hero-v2 h1 {
          font-size: 32px;
        }

        .belle-hero-tagline-v2 {
          font-size: 16px;
          margin-bottom: 24px;
        }

        .belle-cta-group-v2 {
          flex-direction: column;
          align-items: center;
          gap: 12px;
        }

        .belle-btn-v2 {
          width: 100%;
          max-width: 300px;
          justify-content: center;
          padding: 14px 24px;
        }

        .belle-trust-bar {
          flex-direction: column;
          gap: 6px;
        }

        .belle-trust-divider {
          display: none;
        }

        .belle-features-v2 {
          grid-template-columns: 1fr;
          gap: 12px;
          max-width: 400px;
          margin: -24px auto 0;
        }

        .belle-feature-v2 {
          padding: 20px 16px;
          display: flex;
          align-items: center;
          text-align: left;
          gap: 16px;
        }

        a.belle-feature-v2 {
          display: flex;
        }

        .belle-feature-icon-v2 {
          margin: 0;
          flex-shrink: 0;
          width: 44px;
          height: 44px;
        }

        .belle-feature-v2 h2 {
          margin-bottom: 4px;
        }
      }
</style>

{% if section.settings.bg_image != blank %}
  {%- comment -%}
    image_tag's preload: true argument (used further below) doesn't emit a
    <link rel=preload> when called from a section — content_for_header has
    already been flushed by the time this section renders in the body. A
    real preload link is required for the browser to fetch this LCP image
    ahead of everything else, so it's added manually here instead.
  {%- endcomment -%}
  {% # theme-check-disable AssetPreload %}
  <link
    rel="preload"
    as="image"
    href="{{ section.settings.bg_image | image_url: width: 1600 }}"
    imagesrcset="{{ section.settings.bg_image | image_url: width: 800 }} 800w, {{ section.settings.bg_image | image_url: width: 1200 }} 1200w, {{ section.settings.bg_image | image_url: width: 1600 }} 1600w"
    imagesizes="100vw"
    fetchpriority="high"
  >
  {% # theme-check-enable AssetPreload %}
{% endif %}

<section class="belle-hero-v2">
  <!-- Top Contact Bar -->
  <div class="belle-topbar">
    <div class="belle-topbar-content">
      <div class="belle-topbar-item">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
        </svg>
        <a href="https://maps.google.com/?q={{ section.settings.address | url_encode }}">
          {{- section.settings.address -}}
        </a>
      </div>
      <div class="belle-topbar-item">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
        </svg>
        <a href="tel:{{ section.settings.phone | remove: '-' | remove: '(' | remove: ')' | remove: ' ' }}">
          {{- section.settings.phone -}}
        </a>
      </div>
    </div>
  </div>

  <!-- Hero with Background Image -->
  <div class="belle-hero-bg">
    <div class="belle-hero-bg-image">
      {% if section.settings.bg_image != blank %}
        {%- liquid
          assign bg_image = section.settings.bg_image
          assign bg_alt = bg_image.alt | default: "Tennis racquet stringing at Belle's Performance Tennis"
        -%}
        {{-
          bg_image
          | image_url: width: 1600
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            alt: bg_alt,
            sizes: '100vw',
            widths: '800, 1200, 1600'
        -}}
      {% endif %}
    </div>

    <div class="belle-hero-content-v2">
      <!-- Benefit Badge -->
      <a
        href="/pages/about-tennis-stringing-kansas-city-northland"
        class="belle-hero-badge-v2"
        style="text-decoration: none; cursor: pointer;"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M18 18.5c-2.5 0-4.71-1.28-6-3.22-1.29 1.94-3.5 3.22-6 3.22H3v2h3c2.12 0 4.07-.86 5.5-2.25C12.93 19.64 14.88 20.5 17 20.5h4v-2h-3zM19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2zM5 8V7h2v3.82C5.84 10.4 5 9.3 5 8zm14 0c0 1.3-.84 2.4-2 2.82V7h2v1z"/>
        </svg>
        {{ section.settings.badge_text }}
      </a>

      <!-- Business name byline -->
      <p class="belle-hero-byline">{{ section.settings.byline }}</p>

      <!-- Customer-benefit headline -->
      <h1>
        {{ section.settings.headline_line1 -}}
        <br>
        <span>{{ section.settings.headline_line2 }}</span>
      </h1>

      <!-- SEO-only business name (hidden) -->
      <span class="visually-hidden"
        >Belle's Performance Tennis Shop - {{ section.settings.address }} - Professional Racquet Stringing</span
      >

      <!-- Short tagline -->
      <p class="belle-hero-tagline-v2">{{ section.settings.tagline }}</p>

      <!-- CTA Buttons -->
      <div class="belle-cta-group-v2">
        <a
          href="https://calendly.com/bellesperformancetennis-sales/racquet_service"
          data-calendly-modal="true"
          data-calendly-url="https://calendly.com/bellesperformancetennis-sales/racquet_service?utm_source=bellesperformancetennis&utm_medium=cta_button&utm_campaign=racquet_stringing&utm_content=homepage_hero"
          class="belle-btn-v2 belle-btn-primary-v2"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11zM9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z"/>
          </svg>
          {{ section.settings.cta_primary_text }}
        </a>
        <a href="{{ section.settings.cta_secondary_url }}" class="belle-hero-text-link">
          {{ section.settings.cta_secondary_text }}
        </a>
      </div>

      <!-- Trust Bar -->
      <div class="belle-trust-bar">
        {% if section.settings.trust_1 != blank %}
          <div class="belle-trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
            {{ section.settings.trust_1 }}
          </div>
        {% endif %}
        {% if section.settings.trust_2 != blank %}
          <div class="belle-trust-divider"></div>
          <div class="belle-trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
            {{ section.settings.trust_2 }}
          </div>
        {% endif %}
        {% if section.settings.trust_3 != blank %}
          <div class="belle-trust-divider"></div>
          <div class="belle-trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
            {{ section.settings.trust_3 }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  <!-- Feature Cards -->
  <div class="belle-features-wrapper-v2">
    <div class="belle-features-v2">
      {% for block in section.blocks %}
        {% unless block.disabled %}
          {% if block.settings.url != blank %}
            <a href="{{ block.settings.url }}" class="belle-feature-v2" {{ block.shopify_attributes }}>
          {% else %}
            <div class="belle-feature-v2" {{ block.shopify_attributes }}>
          {% endif %}
          <div class="belle-feature-icon-v2">
            {% case block.settings.icon %}
              {% when 'check' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                </svg>
              {% when 'school' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82zM12 3L1 9l11 6 9-4.91V17h2V9L12 3z"/>
                </svg>
              {% when 'trophy' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2zM5 8V7h2v3.82C5.84 10.4 5 9.3 5 8zm14 0c0 1.3-.84 2.4-2 2.82V7h2v1z"/>
                </svg>
              {% when 'calendar' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11zM9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm-8 4H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z"/>
                </svg>
              {% when 'racquet' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
                </svg>
              {% when 'badge' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
                </svg>
              {% else %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                </svg>
            {% endcase %}
          </div>
          <div>
            <h2>{{ block.settings.title }}</h2>
            <p>{{ block.settings.description }}</p>
          </div>
          {% if block.settings.url != blank %}</a>{% else %}</div>{% endif %}
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Belle's Hero",
  "tag": "section",
  "class": "section-belle-hero",
  "settings": [
    {
      "type": "header",
      "content": "Contact Bar"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": "Kansas City, MO 64155"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone Number",
      "default": "816-938-7622"
    },
    {
      "type": "header",
      "content": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image",
      "info": "Recommended: landscape photo, 1600px wide minimum. Your stringing close-up or machine photo works best."
    },
    {
      "type": "header",
      "content": "Hero Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Drop Off at a Northland QuikTrip"
    },
    {
      "type": "text",
      "id": "byline",
      "label": "Business Name Byline",
      "default": "Belle's Performance Tennis Shop"
    },
    {
      "type": "text",
      "id": "headline_line1",
      "label": "Headline Line 1",
      "default": "Expert Racquet Stringing"
    },
    {
      "type": "text",
      "id": "headline_line2",
      "label": "Headline Line 2 (Gold accent)",
      "default": "Ready When You Are"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "Convenient drop-off & pickup across the Kansas City Northland. We track your setup and return your racquet strung right."
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_primary_text",
      "label": "Primary Button Text",
      "default": "Book Your Appointment"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "Secondary Button Text",
      "default": "See Pricing"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary Button Link",
      "info": "Set this to your Pricing page: /pages/racquet-stringing-prices-kansas-city-northland"
    },
    {
      "type": "header",
      "content": "Trust Bar"
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Trust Item 1",
      "default": "$40\u2013$55 total, string included"
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Trust Item 2",
      "default": "Most racquets ready in 2–3 days"
    },
    {
      "type": "text",
      "id": "trust_3",
      "label": "Trust Item 3",
      "default": "USRSA Member"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "check", "label": "Checkmark" },
            { "value": "school", "label": "School / Delivery" },
            { "value": "trophy", "label": "Trophy" },
            { "value": "calendar", "label": "Calendar" },
            { "value": "racquet", "label": "Racquet / Gear" },
            { "value": "badge", "label": "Shield / Badge" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Feature description"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL",
          "info": "Optional. Makes the card clickable. Use /pages/demo-racquet-program for the demo card."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Belle's Hero",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "check",
            "title": "We Track Your Setup",
            "description": "Consistent results every time, no guessing."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "school",
            "title": "QuikTrip Drop-Off",
            "description": "We meet at a local QuikTrip. Drop off in 2 minutes, pick up when it's ready."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "racquet",
            "title": "No Surprises, No Upselling",
            "description": "You'll know the cost upfront. We don't push upgrades you don't need."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "school",
            "title": "Free Demo Racquet",
            "description": "Borrow a Solinco while yours is being strung."
          }
        }
      ]
    }
  ]
}
{% endschema %}
