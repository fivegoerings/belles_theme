{% comment %}
  Belle's Performance Tennis - Contact Page
  Branded contact page with form, contact info, and quick action links.
  Uses Shopify's built-in contact form for email delivery.
{% endcomment %}

<style>
.belle-contact {
  --belle-green: #1a3c2a;
  --belle-green-light: #2a5a3a;
  --belle-gold: #c8a951;
  --belle-cream: #faf9f6;
  --belle-charcoal: #2d2d2d;
}

/* Hero */
.belle-contact-hero {
  background: linear-gradient(135deg, var(--belle-green) 0%, var(--belle-green-light) 100%);
  padding: 48px 24px 40px;
  text-align: center;
  position: relative;
}

.belle-contact-hero::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 4px;
  background: var(--belle-gold);
}

.belle-contact-hero h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 44px;
  color: #fff;
  margin: 0 0 12px;
  letter-spacing: 1.5px;
  line-height: 1.1;
}

.belle-contact-hero p {
  font-family: 'Source Sans Pro', sans-serif;
  font-size: 17px;
  color: rgba(255, 255, 255, 0.85);
  margin: 0;
  max-width: 520px;
  margin-left: auto;
  margin-right: auto;
  line-height: 1.5;
}

/* Quick Actions */
.belle-contact-actions {
  background: var(--belle-cream);
  padding: 40px 24px;
}

.belle-contact-actions-grid {
  max-width: 900px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 20px;
}

.belle-contact-action {
  background: #fff;
  border-radius: 12px;
  padding: 28px 24px;
  text-align: center;
  box-shadow: 0 2px 12px rgba(0,0,0,0.05);
  border-top: 3px solid var(--belle-gold);
  text-decoration: none;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  display: block;
}

.belle-contact-action:hover {
  transform: translateY(-3px);
  box-shadow: 0 6px 20px rgba(0,0,0,0.08);
}

.belle-contact-action-icon {
  width: 48px;
  height: 48px;
  margin: 0 auto 12px;
  background: linear-gradient(135deg, var(--belle-green) 0%, var(--belle-green-light) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.belle-contact-action-icon svg {
  width: 22px;
  height: 22px;
  fill: var(--belle-gold);
}

.belle-contact-action h3 {
  font-family: 'Source Sans Pro', sans-serif;
  font-size: 16px;
  font-weight: 700;
  color: var(--belle-green);
  margin: 0 0 6px;
}

.belle-contact-action p {
  font-family: 'Source Sans Pro', sans-serif;
  font-size: 14px;
  color: #666;
  margin: 0;
  line-height: 1.4;
}

/* Main Content Area */
.belle-contact-main {
  padding: 56px 24px;
  background: #fff;
}

.belle-contact-main-grid {
  max-width: 900px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 48px;
}

/* Form */
.belle-contact-form-section h2 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 32px;
  color: var(--belle-green);
  margin: 0 0 8px;
  letter-spacing: 1px;
}

.belle-contact-form-section > p {
  font-family: 'Source Sans Pro', sans-serif;
  font-size: 15px;
  color: #666;
  margin: 0 0 28px;
  line-height: 1.5;
}

.belle-contact-form {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.belle-contact-field-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.belle-contact-field {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.belle-contact-field label {
  font-family: 'Source Sans Pro', sans-serif;
  font-size: 14px;
  font-weight: 600;
  color: var(--belle-charcoal);
}

.belle-contact-field label .belle-required {
  color: #c0392b;
}

.belle-contact-field input,
.belle-contact-field textarea,
.belle-contact-field select {
  font-family: 'Source Sans Pro', sans-serif;
  font-size: 15px;
  padding: 12px 14px;
  border: 2px solid #e0e0e0;
  border-radius: 8px;
  background: #fff;
  color: var(--belle-charcoal);
  transition: border-color 0.2s ease;
  width: 100%;
  box-sizing: border-box;
}

.belle-contact-field input:focus,
.belle-contact-field textarea:focus,
.belle-contact-field select:focus {
  outline: none;
  border-color: var(--belle-green);
}

.belle-contact-field textarea {
  resize: vertical;
  min-height: 120px;
}

.belle-contact-submit {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 14px 32px;
  font-family: 'Source Sans Pro', sans-serif;
  font-size: 16px;
  font-weight: 600;
  background: #f4b942;
  color: var(--belle-green);
  border: 2px solid #f4b942;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.3s ease;
  align-self: flex-start;
}

.belle-contact-submit:hover {
  background: #f7c755;
  transform: translateY(-2px);
}

/* Success / Error Messages */
.belle-contact-success {
  background: #e8f5e9;
  border: 2px solid var(--belle-green);
  border-radius: 8px;
  padding: 16px 20px;
  margin-bottom: 20px;
}

.belle-contact-success p {
  font-family: 'Source Sans Pro', sans-serif;
  font-size: 15px;
  color: var(--belle-green);
  margin: 0;
  font-weight: 600;
}

.belle-contact-error {
  background: #fce4ec;
  border: 2px solid #c0392b;
  border-radius: 8px;
  padding: 16px 20px;
  margin-bottom: 20px;
}

.belle-contact-error p {
  font-family: 'Source Sans Pro', sans-serif;
  font-size: 15px;
  color: #c0392b;
  margin: 0;
  font-weight: 600;
}

/* Sidebar Info */
.belle-contact-info h2 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 28px;
  color: var(--belle-green);
  margin: 0 0 24px;
  letter-spacing: 1px;
}

.belle-contact-info-item {
  display: flex;
  gap: 14px;
  margin-bottom: 24px;
  align-items: flex-start;
}

.belle-contact-info-icon {
  width: 40px;
  height: 40px;
  min-width: 40px;
  background: var(--belle-cream);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.belle-contact-info-icon svg {
  width: 20px;
  height: 20px;
  fill: var(--belle-green);
}

.belle-contact-info-item h4 {
  font-family: 'Source Sans Pro', sans-serif;
  font-size: 15px;
  font-weight: 700;
  color: var(--belle-green);
  margin: 0 0 4px;
}

.belle-contact-info-item p {
  font-family: 'Source Sans Pro', sans-serif;
  font-size: 14px;
  color: #666;
  margin: 0;
  line-height: 1.5;
}

.belle-contact-info-item a {
  color: var(--belle-green);
  text-decoration: none;
  font-weight: 600;
}

.belle-contact-info-item a:hover {
  color: var(--belle-gold);
}

/* Responsive */
@media (max-width: 768px) {
  .belle-contact-hero {
    padding: 36px 20px 32px;
  }

  .belle-contact-hero h1 {
    font-size: 32px;
  }

  .belle-contact-actions {
    padding: 28px 20px;
  }

  .belle-contact-actions-grid {
    grid-template-columns: 1fr;
    gap: 12px;
  }

  .belle-contact-action {
    display: grid;
    grid-template-columns: 48px 1fr;
    grid-template-rows: auto auto;
    gap: 0 14px;
    text-align: left;
    padding: 20px;
  }

  .belle-contact-action-icon {
    grid-row: 1 / 3;
    margin: 0;
    align-self: center;
  }

  .belle-contact-action h3 {
    align-self: end;
  }

  .belle-contact-action p {
    align-self: start;
  }

  .belle-contact-main {
    padding: 40px 20px;
  }

  .belle-contact-main-grid {
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .belle-contact-field-row {
    grid-template-columns: 1fr;
  }

  .belle-contact-submit {
    width: 100%;
  }
}
</style>

<div class="belle-contact">

  <!-- Hero -->
  <section class="belle-contact-hero">
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.subheading }}</p>
  </section>

  <!-- Quick Actions -->
  <section class="belle-contact-actions">
    <div class="belle-contact-actions-grid">
      <a href="#" data-calendly-modal="true" class="belle-contact-action">
        <div class="belle-contact-action-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11zM9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z"/></svg>
        </div>
        <h3>Book an Appointment</h3>
        <p>Schedule your racquet drop-off online</p>
      </a>

      <a href="tel:{{ section.settings.phone | remove: '-' | remove: '(' | remove: ')' | remove: ' ' }}" class="belle-contact-action">
        <div class="belle-contact-action-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
        </div>
        <h3>Call or Text</h3>
        <p>{{ section.settings.phone }}</p>
      </a>

      <a href="mailto:{{ section.settings.email }}" class="belle-contact-action">
        <div class="belle-contact-action-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
        </div>
        <h3>Email Us</h3>
        <p>{{ section.settings.email }}</p>
      </a>
    </div>
  </section>

  <!-- Form + Info -->
  <section class="belle-contact-main">
    <div class="belle-contact-main-grid">

      <!-- Form Column -->
      <div class="belle-contact-form-section">
        <h2>Send Us a Message</h2>
        <p>Have a question about stringing, strings, or service? Drop us a note and we'll get back to you.</p>

        {%- form 'contact', id: 'BelleContactForm' -%}
          {%- if form.posted_successfully? -%}
            <div class="belle-contact-success">
              <p>Thanks for reaching out! We'll get back to you shortly.</p>
            </div>
          {%- endif -%}

          {%- if form.errors -%}
            <div class="belle-contact-error">
              <p>Something went wrong — please check your email address and try again.</p>
            </div>
          {%- endif -%}

          <div class="belle-contact-form">
            <div class="belle-contact-field-row">
              <div class="belle-contact-field">
                <label for="BelleContact-name">Name</label>
                <input
                  type="text"
                  id="BelleContact-name"
                  name="contact[{{ 'templates.contact.form.name' | t }}]"
                  value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                  placeholder="Your name"
                >
              </div>
              <div class="belle-contact-field">
                <label for="BelleContact-email">Email <span class="belle-required">*</span></label>
                <input
                  type="email"
                  id="BelleContact-email"
                  name="contact[email]"
                  value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                  placeholder="your@email.com"
                  required
                  aria-required="true"
                  {% if form.errors contains 'email' %}aria-invalid="true"{% endif %}
                >
              </div>
            </div>

            <div class="belle-contact-field">
              <label for="BelleContact-phone">Phone</label>
              <input
                type="tel"
                id="BelleContact-phone"
                name="contact[{{ 'templates.contact.form.phone' | t }}]"
                value="{% if form.phone %}{{ form.phone }}{% endif %}"
                placeholder="(555) 555-5555"
              >
            </div>

            <div class="belle-contact-field">
              <label for="BelleContact-subject">Subject</label>
              <select id="BelleContact-subject" name="contact[Subject]">
                <option value="General Question">General Question</option>
                <option value="Stringing Service">Stringing Service</option>
                <option value="String Recommendation">String Recommendation</option>
                <option value="Racquet or Accessories">Racquet or Accessories</option>
                <option value="Team / Coach Inquiry">Team / Coach Inquiry</option>
                <option value="Other">Other</option>
              </select>
            </div>

            <div class="belle-contact-field">
              <label for="BelleContact-message">Message</label>
              <textarea
                id="BelleContact-message"
                name="contact[{{ 'templates.contact.form.comment' | t }}]"
                placeholder="How can we help?"
              >{{ form.body }}</textarea>
            </div>

            <button type="submit" class="belle-contact-submit">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
              Send Message
            </button>
          </div>
        {%- endform -%}
      </div>

      <!-- Info Column -->
      <div class="belle-contact-info">
        <h2>Get in Touch</h2>

        <div class="belle-contact-info-item">
          <div class="belle-contact-info-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
          </div>
          <div>
            <h4>Phone</h4>
            <p><a href="tel:{{ section.settings.phone | remove: '-' | remove: '(' | remove: ')' | remove: ' ' }}">{{ section.settings.phone }}</a></p>
            <p>Call or text anytime</p>
          </div>
        </div>

        <div class="belle-contact-info-item">
          <div class="belle-contact-info-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
          </div>
          <div>
            <h4>Email</h4>
            <p><a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a></p>
          </div>
        </div>

        <div class="belle-contact-info-item">
          <div class="belle-contact-info-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          </div>
          <div>
            <h4>Service Area</h4>
            <p>Kansas City Northland<br>By appointment only</p>
          </div>
        </div>

        <div class="belle-contact-info-item">
          <div class="belle-contact-info-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
          </div>
          <div>
            <h4>Turnaround</h4>
            <p>Most racquets ready in 2–3 days</p>
          </div>
        </div>
      </div>

    </div>
  </section>

</div>

{% schema %}
{
  "name": "Belle's Contact",
  "tag": "section",
  "class": "section-belle-contact",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get in Touch"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Questions about stringing, strings, or service? We'd love to hear from you."
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone Number",
      "default": "816-938-7622"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email Address",
      "default": "sales@bellesperformancetennis.com"
    }
  ]
}
{% endschema %}
