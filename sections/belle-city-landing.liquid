          <span class="belle-city-value-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="#c8a951"><path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/></svg></span>
          <h3>{{ section.settings.value_4_title | default: "Gamma Progression II ELS" }}</h3>
          <p>{{ section.settings.value_4_text | default: "Your racquet is strung on a professional electronic constant-pull machine. It holds consistent tension through the whole job." }}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Local Context (hidden unless populated) -->
  {% if section.settings.local_paragraph_1 != blank %}
  <section class="belle-city-local">
    <div class="belle-city-local-container">
      {% if section.settings.local_heading != blank %}
        <h2>{{ section.settings.local_heading }}</h2>
      {% endif %}
      <p>{{ section.settings.local_paragraph_1 }}</p>
      {% if section.settings.local_paragraph_2 != blank %}
        <p>{{ section.settings.local_paragraph_2 }}</p>
      {% endif %}
      {% if section.settings.local_paragraph_3 != blank %}
        <p>{{ section.settings.local_paragraph_3 }}</p>
      {% endif %}
    </div>
  </section>
  {% endif %}

  <!-- Testimonial -->
  {% if section.settings.testimonial_text != blank %}
  <section class="belle-city-testimonial">
    <div class="belle-city-testimonial-container">
      <div class="belle-stars" aria-label="5 star rating">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
      <blockquote>{{ section.settings.testimonial_text }}</blockquote>
      {% if section.settings.testimonial_author != blank %}
        <cite>{{ section.settings.testimonial_author }}</cite>
      {% endif %}
    </div>
  </section>
  {% endif %}


